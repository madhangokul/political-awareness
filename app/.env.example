# Supabase (copy from `supabase start` output or your Supabase project dashboard)
VITE_SUPABASE_URL=http://127.0.0.1:54391
VITE_SUPABASE_ANON_KEY=

# PWA Web Push (generate with: npx web-push generate-vapid-keys)
# VITE_ prefix exposes the public key to the browser — that is intentional.
VITE_VAPID_PUBLIC_KEY=

# These go in supabase/functions/.env (never in the app bundle):
# VAPID_SUBJECT=mailto:admin@yourdomain.com
# VAPID_PRIVATE_KEY=
